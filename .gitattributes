# Ensure consistent line endings across platforms
* text=auto

# Force LF line endings for shell scripts (required for Husky hooks)
.husky/* text eol=lf
*.sh text eol=lf

# Force LF for common config files
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
