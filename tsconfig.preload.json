{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "outDir": "./dist-electron",
    "target": "ES2022",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "noEmit": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src-electron/preload.ts"],
  "exclude": ["node_modules", "dist", "src"]
}
