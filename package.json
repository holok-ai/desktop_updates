{
  "name": "holokai-desktop-svelte",
  "version": "1.0.0",
  "description": "Holokai Desktop - Reference Electron + Svelte application demonstrating architecture patterns",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:watch\" -n \"VITE,ELECTRON\" -c \"blue,green\"",
    "electron:watch": "concurrently \"npm run build:electron\" \"nodemon --watch dist-electron --delay 1000ms --exec electron .\" -n \"TSC,APP\" -c \"yellow,magenta\"",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}))\"",
    "build:prod": "npm run build && npm run build:electron",
    "package": "npm run build:prod && electron-builder",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . --ext .ts,.js,.svelte",
    "lint:fix": "eslint . --ext .ts,.js,.svelte --fix",
    "format": "prettier --write \"**/*.{ts,js,svelte,json,css,md}\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "electron",
    "svelte",
    "typescript",
    "ipc",
    "context-bridge"
  ],
  "author": "Holokai",
  "license": "MIT",
  "dependencies": {
    "electron-log": "^5.4.3",
    "electron-store": "^8.1.0",
    "playwright": "^1.56.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@tsconfig/svelte": "^5.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-secrets": "^2.2.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.4.0",
    "nodemon": "^3.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^4.2.0",
    "svelte-check": "^3.6.0",
    "svelte-eslint-parser": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.holokai.desktop.svelte",
    "productName": "Holokai Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
