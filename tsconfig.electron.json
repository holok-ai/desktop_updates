{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": ".tsbuildinfo.electron",
    "module": "NodeNext",
    "outDir": "./dist-electron",
    "rootDir": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "moduleResolution": "nodenext",
    "noEmit": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false
  },
  "include": ["src-electron/**/*.ts", "src-shared/**/*.ts"],
  "exclude": ["node_modules", "dist", "src", "src-electron/preload.ts"]
}
