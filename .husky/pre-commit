#!/usr/bin/env sh

# Source common Windows workarounds
. "$(dirname "$0")/common.sh"

# Ensure npm (via nvm) is available for non-interactive Git shells
export NVM_DIR="$HOME/.nvm"
if [ -s "$NVM_DIR/nvm.sh" ]; then
  # shellcheck source=/dev/null
  . "$NVM_DIR/nvm.sh"
  nvm use --silent >/dev/null 2>&1
fi

# Enforce minimum Node major version from .nvmrc
REQUIRED_MAJOR=$(cat "$(dirname "$0")/../.nvmrc" | tr -d 'v' | cut -d. -f1)
NODE_MAJOR=$(node -v | cut -d. -f1 | tr -d 'v')
if [ "$NODE_MAJOR" -lt "$REQUIRED_MAJOR" ]; then
  echo "❌ Node ${REQUIRED_MAJOR}+ required (found $(node -v)). Run: nvm install ${REQUIRED_MAJOR}"
  exit 1
fi

# Exit on first error (fail-fast)
set -e

echo "🔍 Running pre-commit checks..."

# Phase 1: Code Quality (staged files only via lint-staged)
echo "📝 Phase 1: Linting and formatting..."
npx lint-staged

# Phase 2: Type Safety (full project with incremental compilation)
echo "🔷 Phase 2: Type checking..."
npm run type-check

# Phase 3: Svelte Check
echo "🧡 Phase 3: Svelte checking..."
npx svelte-check

# Phase 4: Security Scanning
echo "🔒 Phase 4: Security scanning..."
npm run security:audit
npm run security:secrets

# Phase 5: Advanced Security (Optional - graceful degradation)
# Snyk: Runs if SNYK_ENABLED=1 or snyk is authenticated
if [ "$SNYK_ENABLED" = "1" ]; then
  echo "🔐 Phase 5a: Snyk vulnerability scanning..."
  npm run precommit:snyk
fi

echo "✅ All pre-commit checks passed!"
